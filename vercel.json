{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "seller.html",
          "signin.html",
          "profile.html",
          "buyer.js",
          "seller.js",
          "signin.js",
          "profile.js",
          "styles.css",
          "data/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
